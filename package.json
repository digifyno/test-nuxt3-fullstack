{
  "name": "nuxt3-fullstack",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx prisma generate && npm run db:setup && nuxt build",
    "dev": "npx prisma generate && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "typecheck": "npx nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "db:setup": "node scripts/db-setup.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.16.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@tailwindcss/vite": "^4.0.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.8"
  }
}
